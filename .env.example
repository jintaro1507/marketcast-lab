# =============================================================================
# Marketcast Lab — 環境変数テンプレート
# このファイルは Git 管理対象。実値は絶対に書かないこと。
# ローカル開発用の実値は supabase/.env.local に記載（Git 管理外）。
# =============================================================================

# Stripe — テストモード用識別子（公開可）
STRIPE_PRODUCT_ID=prod_U1SxKterJnpz3k
STRIPE_PRICE_ID=price_1T1w3JBACRTyruDceD4g8kdG

# Stripe — シークレット（実値は絶対に記載しない）
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# アプリケーション URL（Stripe Checkout リダイレクト先・CORS 許可オリジンの基準）
# ローカル: http://localhost:8000
# 本番:     https://jintaro1507.github.io/marketcast-lab
SITE_URL=http://localhost:8000

# Supabase — Edge Functions 実行環境から自動注入される。手動設定は不要。
# `supabase functions serve` 実行時はローカル Supabase の値が自動設定される。
# リモート deploy 時は `supabase secrets set` で設定する。
# SUPABASE_URL=（自動）
# SUPABASE_ANON_KEY=（自動）
# SUPABASE_SERVICE_ROLE_KEY=（自動）
