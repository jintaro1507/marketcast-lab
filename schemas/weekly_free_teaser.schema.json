{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "weekly_free_teaser.schema.json",
  "title": "WeeklyFreeTeaserSchema",
  "description": "Weekly Marketcast の無料公開ティーザーコンテンツ。weekly_reports.free_teaser JSONB カラムに保存する内容。restricted 生値・有料情報（スコア・Timeline・反応詳細）を含まない。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "week_id",
    "title",
    "period_start",
    "period_end",
    "env_label",
    "teaser_summary",
    "disclaimer"
  ],
  "properties": {
    "week_id": {
      "type": "string",
      "pattern": "^\\d{4}-W(0[1-9]|[1-4][0-9]|5[0-3])$",
      "description": "ISO 8601 週番号（例: 2026-W25）"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "レポートタイトル（例: Weekly Marketcast 2026年第25週（6/15〜6/19））"
    },
    "period_start": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "対象週の月曜日（YYYY-MM-DD）"
    },
    "period_end": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "対象週の金曜日（YYYY-MM-DD、市場最終営業日の基準）"
    },
    "env_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "description": "今週の市場環境ラベル（例: VIX警戒・エクイティ下落）"
    },
    "teaser_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "要約文。変化率（%・pt）は含めてよいが restricted 生値は不可。200字以内。"
    },
    "featured_theme": {
      "description": "注目テーマ（group_metadata.json 由来の承認済みテキストのみ）。ない場合は null。",
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["tag", "label", "summary"],
          "properties": {
            "tag": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "description": "cause_tag 識別子"
            },
            "label": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "description": "表示ラベル"
            },
            "summary": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500,
              "description": "承認済み説明文（group_metadata.json の summary をそのまま使用）"
            }
          }
        }
      ]
    },
    "top_match_preview": {
      "description": "類似局面プレビュー（1件）。無料ティーザーに含めてよい情報: event_name, event_date のみ。スコア・Timeline・反応詳細・中期反転は含めない。ない場合は null。",
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["event_name", "event_date"],
          "properties": {
            "event_name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200,
              "description": "類似局面名"
            },
            "event_date": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "類似局面の日付（YYYY-MM-DD）"
            }
          }
        }
      ]
    },
    "disclaimer": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "免責文言"
    }
  },
  "$defs": {}
}
